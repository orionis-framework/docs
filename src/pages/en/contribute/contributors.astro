---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { ContributorsAPI, type ContributorData } from '../../../utils/contributors';

const contributors = await ContributorsAPI.fetchContributors();
const totalCommits = contributors.reduce((sum, c) => sum + c.totalContributions, 0);
---

<StarlightPage
  frontmatter={{
    title: "Contributors",
    description: "Meet the community powering Orionis Framework and discover how to join the movement"
  }}
>
  <div class="contributors-page">

    <!-- Hero Section -->
    <section class="hero-section">
      <p class="hero-tagline">The heart of Orionis beats thanks to its community</p>
      <p class="hero-description">
        Every line of code, every test, every shared idea builds something greater than a framework —
        a community of developers transforming Python development.
      </p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number">{contributors.length}</span>
          <span class="stat-label">Contributors</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">{totalCommits}</span>
          <span class="stat-label">Commits</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">4</span>
          <span class="stat-label">Repositories</span>
        </div>
      </div>
    </section>

    <!-- Ways to contribute -->
    <section class="ways-section">
      <h2 class="section-title">Ways to Contribute</h2>
      <p class="section-subtitle">You don't need to be an expert to make a difference</p>
      <div class="ways-grid">
        <div class="way-card">
          <div class="way-icon">⚡</div>
          <h3>Code</h3>
          <p>Fix bugs, implement new features, or improve performance. Every PR counts.</p>
        </div>
        <div class="way-card">
          <div class="way-icon">📖</div>
          <h3>Documentation</h3>
          <p>Improve guides, add examples, or translate content. Clear docs multiply the impact.</p>
        </div>
        <div class="way-card">
          <div class="way-icon">🧪</div>
          <h3>Testing</h3>
          <p>Write tests, report edge cases, or validate features. Tests are the backbone.</p>
        </div>
        <div class="way-card">
          <div class="way-icon">💡</div>
          <h3>Ideas</h3>
          <p>Propose improvements, discuss designs, or share your experience. Great ideas are born from conversation.</p>
        </div>
      </div>
    </section>

    <!-- Contributors Gallery -->
    <section class="gallery-section">
      <h2 class="section-title">Wall of Fame</h2>
      <p class="section-subtitle">People who have dedicated their time and talent to making Orionis exceptional</p>

      <div class="contributors-list">
        {contributors.map((contributor) => (
          <a href={contributor.html_url || '#'} target={contributor.html_url ? '_blank' : undefined} rel={contributor.html_url ? 'noopener noreferrer' : undefined} class="contributor-card">
            <div class="card-avatar-ring">
              <img src={contributor.avatar_url} alt={contributor.login} class="card-avatar" loading="lazy" />
            </div>
            <div class="card-info">
              <div class="card-name-row">
                <strong class="card-username">{contributor.login}</strong>
                {contributor.rank <= 3 && (
                  <span class="rank-badge">{ContributorsAPI.getRankBadge(contributor.rank)}</span>
                )}
              </div>
              <span class="card-commits">{contributor.totalContributions} commits</span>
            </div>
            <div class="card-pills">
              <span class={`pill pill-framework${contributor.frameworkContributions === 0 ? ' pill-off' : ''}`}>Framework {contributor.frameworkContributions}</span>
              <span class={`pill pill-skeleton${contributor.skeletonContributions === 0 ? ' pill-off' : ''}`}>Skeleton {contributor.skeletonContributions}</span>
              <span class={`pill pill-docs${contributor.docsContributions === 0 ? ' pill-off' : ''}`}>Docs {contributor.docsContributions}</span>
              <span class={`pill pill-web${contributor.webContributions === 0 ? ' pill-off' : ''}`}>Web {contributor.webContributions}</span>
            </div>
          </a>
        ))}
      </div>

      {contributors.length === 0 && (
        <div class="loading">
          <p>Loading contributors...</p>
        </div>
      )}
    </section>

    <!-- How to start -->
    <section class="steps-section">
      <h2 class="section-title">Your First Contribution in 5 Steps</h2>
      <p class="section-subtitle">First time contributing? Follow this quick guide</p>
      <div class="steps-timeline">
        <div class="step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Fork the repository</h3>
            <p>Fork <a href="https://github.com/orionis-framework/framework" target="_blank" rel="noopener noreferrer">Framework</a> or <a href="https://github.com/orionis-framework/skeleton" target="_blank" rel="noopener noreferrer">Skeleton</a> to your GitHub account.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Set up your environment</h3>
            <p>Clone your fork, install dependencies, and verify that existing tests pass correctly.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Create a branch</h3>
            <p>Descriptive branch from the appropriate base: stable version for fixes, <code>master</code> for features.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Implement and test</h3>
            <p>Follow the <a href="/en/contribute/guide">style conventions</a>. Include type hints, docstrings, and tests.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Open a Pull Request</h3>
            <p>Describe the problem, the changes, and how to test them. Mark as <em>Ready for review</em>.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why contribute -->
    <section class="why-section">
      <h2 class="section-title">Why Contribute to Orionis?</h2>
      <div class="why-grid">
        <div class="why-item">
          <span class="why-icon">🎓</span>
          <div>
            <strong>Learn in depth</strong>
            <p>Work with advanced patterns like IoC, async middleware, and a Rust-powered HTTP core.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-icon">📋</span>
          <div>
            <strong>Build your portfolio</strong>
            <p>Every accepted PR is a verifiable contribution to a real open source project.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-icon">🤝</span>
          <div>
            <strong>Connect with the community</strong>
            <p>Collaborate with developers who share your passion for quality code.</p>
          </div>
        </div>
        <div class="why-item">
          <span class="why-icon">⭐</span>
          <div>
            <strong>Leave your mark</strong>
            <p>Your name will appear on the contributor wall and in the project's history forever.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Final -->
    <section class="cta-section">
      <div class="cta-content">
        <span class="cta-icon">🚀</span>
        <h2>Ready to get started?</h2>
        <p>Pick an issue that inspires you and open your first Pull Request. The community is waiting for you.</p>
        <div class="cta-actions">
          <a href="https://github.com/orionis-framework/framework" class="cta-btn primary" target="_blank" rel="noopener noreferrer">
            <span>⚡ Framework Core</span>
          </a>
          <a href="https://github.com/orionis-framework/skeleton" class="cta-btn secondary" target="_blank" rel="noopener noreferrer">
            <span>🏗️ Skeleton Template</span>
          </a>
          <a href="/en/contribute/guide" class="cta-btn tertiary">
            <span>📘 Contribution Guide</span>
          </a>
        </div>
        <p class="cta-hint">
          Look for issues labeled <strong>good first issue</strong> if this is your first open source contribution.
        </p>
      </div>
    </section>

  </div>

  <style>
    :global(.right-sidebar-container) {
      display: none !important;
    }
    :global(.main-frame) {
      grid-template-columns: var(--sl-sidebar-width) 1fr !important;
    }

    .contributors-page {
      max-width: none;
      width: 100%;
      margin: 0;
      padding: 0;
    }

    /* ── Section common ── */
    .section-title {
      text-align: center;
      font-size: 1.6rem;
      font-weight: 700;
      color: #134675;
      margin: 0 0 0.25rem 0;
    }
    .section-subtitle {
      text-align: center;
      color: #64748b;
      font-size: 1rem;
      margin: 0 0 2rem 0;
    }

    /* ── Hero ── */
    .hero-section {
      text-align: center;
      padding: 2.5rem 2rem 2rem;
      background: linear-gradient(135deg, #f0f7ff 0%, #e8f4f8 50%, #fef9e7 100%);
      border-radius: 16px;
      margin-bottom: 2.5rem;
      border: 1px solid #e2e8f0;
    }
    .hero-tagline {
      font-size: 1.3rem;
      font-weight: 700;
      color: #134675;
      margin: 0 0 0.75rem 0;
      line-height: 1.3;
    }
    .hero-description {
      font-size: 1rem;
      color: #475569;
      max-width: 680px;
      margin: 0 auto 2rem;
      line-height: 1.7;
    }
    .hero-stats {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: #134675;
      line-height: 1;
    }
    .stat-label {
      font-size: 0.85rem;
      color: #64748b;
      margin-top: 0.25rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 500;
    }
    .stat-divider {
      width: 1px;
      height: 40px;
      background: #cbd5e1;
    }

    /* ── Ways to contribute ── */
    .ways-section {
      margin-bottom: 2.5rem;
      padding: 0 1rem;
    }
    .ways-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.25rem;
    }
    .way-card {
      background: white;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.25s ease;
    }
    .way-card:hover {
      border-color: #4CC9F0;
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(76, 201, 240, 0.15);
    }
    .way-icon {
      font-size: 2rem;
      margin-bottom: 0.75rem;
    }
    .way-card h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #134675;
      margin: 0 0 0.5rem 0;
    }
    .way-card p {
      font-size: 0.88rem;
      color: #64748b;
      margin: 0;
      line-height: 1.5;
    }

    /* ── Contributors Gallery ── */
    .gallery-section {
      margin-bottom: 2.5rem;
      padding: 0 1rem;
    }
    .contributors-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .contributor-card {
      display: grid;
      grid-template-columns: 48px minmax(120px, 180px) 1fr;
      align-items: center;
      gap: 1rem;
      height: 72px;
      padding: 0 1.25rem;
      border: 1.5px solid #e2e8f0;
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      background: white;
      transition: all 0.2s ease;
      box-sizing: border-box;
    }
    .contributor-card:hover {
      border-color: #4CC9F0;
      box-shadow: 0 4px 16px rgba(76, 201, 240, 0.12);
    }
    .card-avatar-ring {
      width: 42px;
      height: 42px;
      border-radius: 50%;
      padding: 2px;
      background: linear-gradient(135deg, #4CC9F0, #134675);
      flex-shrink: 0;
    }
    .card-avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      display: block;
    }
    .card-info {
      display: flex;
      flex-direction: column;
      justify-content: center;
      min-width: 0;
    }
    .card-name-row {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }
    .card-username {
      font-size: 0.92rem;
      font-weight: 700;
      color: #134675;
      line-height: 1.3;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .rank-badge {
      font-size: 0.9rem;
      flex-shrink: 0;
      line-height: 1;
    }
    .card-commits {
      font-size: 0.75rem;
      font-weight: 600;
      color: #4CC9F0;
      line-height: 1.3;
    }
    .card-pills {
      display: flex;
      gap: 0.35rem;
      justify-content: flex-end;
      flex-wrap: wrap;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.2rem 0.55rem;
      border-radius: 9999px;
      font-size: 0.67rem;
      font-weight: 600;
      line-height: 1;
      white-space: nowrap;
      height: 22px;
      box-sizing: border-box;
    }
    .pill-framework { background: #e0f2fe; color: #0369a1; }
    .pill-skeleton { background: #fef3c7; color: #92400e; }
    .pill-docs { background: #dcfce7; color: #166534; }
    .pill-web { background: #f3e8ff; color: #7c3aed; }
    .pill-off { opacity: 0.25; }
    .loading {
      text-align: center;
      padding: 2rem;
      color: var(--sl-color-gray-3);
    }

    /* Dark mode */
    :global([data-theme="dark"]) .contributor-card {
      background: #0f172a;
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .contributor-card:hover { border-color: #4CC9F0; }
    :global([data-theme="dark"]) .card-username { color: #e2e8f0; }
    :global([data-theme="dark"]) .pill-framework { background: rgba(3,105,161,0.2); color: #7dd3fc; }
    :global([data-theme="dark"]) .pill-skeleton { background: rgba(146,64,14,0.2); color: #fcd34d; }
    :global([data-theme="dark"]) .pill-docs { background: rgba(22,101,52,0.2); color: #86efac; }
    :global([data-theme="dark"]) .pill-web { background: rgba(124,58,237,0.2); color: #c4b5fd; }

    @media (max-width: 600px) {
      .contributor-card {
        grid-template-columns: 42px 1fr;
        height: auto;
        padding: 0.75rem 1rem;
        gap: 0.75rem;
      }
      .card-pills {
        grid-column: 1 / -1;
        justify-content: flex-start;
      }
    }

    /* ── Steps ── */
    .steps-section {
      margin-bottom: 2.5rem;
      padding: 2rem;
      background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
      border-radius: 16px;
      border: 1px solid #e2e8f0;
    }
    .steps-timeline {
      max-width: 640px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .step {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .step-number {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      background: #134675;
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.95rem;
    }
    .step-content {
      flex: 1;
      padding-top: 0.15rem;
    }
    .step-content h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #134675;
      margin: 0 0 0.25rem 0;
    }
    .step-content p {
      font-size: 0.9rem;
      color: #64748b;
      margin: 0;
      line-height: 1.5;
    }
    .step-content a {
      color: #4CC9F0;
      text-decoration: underline;
      font-weight: 500;
    }
    .step-content code {
      background: #e2e8f0;
      padding: 0.1em 0.4em;
      border-radius: 4px;
      font-size: 0.85em;
    }

    /* ── Why contribute ── */
    .why-section {
      margin-bottom: 2.5rem;
      padding: 0 1rem;
    }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }
    .why-item {
      display: flex;
      gap: 0.85rem;
      align-items: flex-start;
      padding: 1.25rem;
      border-radius: 10px;
      background: white;
      border: 2px solid #e2e8f0;
      transition: all 0.2s ease;
    }
    .why-item:hover {
      border-color: #F4C430;
      box-shadow: 0 4px 12px rgba(244, 196, 48, 0.15);
    }
    .why-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
      margin-top: 0.1rem;
    }
    .why-item strong {
      display: block;
      font-size: 0.95rem;
      color: #134675;
      margin-bottom: 0.25rem;
    }
    .why-item p {
      font-size: 0.88rem;
      color: #64748b;
      margin: 0;
      line-height: 1.5;
    }

    /* ── CTA ── */
    .cta-section {
      margin-bottom: 1rem;
    }
    .cta-content {
      text-align: center;
      padding: 2.5rem 2rem;
      background: linear-gradient(135deg, #134675 0%, #1a5a8a 50%, #0d3454 100%);
      border-radius: 16px;
      position: relative;
      overflow: hidden;
    }
    .cta-content::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #4CC9F0, #F4C430, #4CC9F0);
    }
    .cta-icon {
      font-size: 2rem;
      display: block;
      margin-bottom: 0.5rem;
    }
    .cta-content h2 {
      color: white;
      font-size: 1.5rem;
      margin: 0 0 0.5rem 0;
    }
    .cta-content > p {
      color: #b0c6d6;
      font-size: 1rem;
      margin: 0 0 1.5rem 0;
      line-height: 1.6;
    }
    .cta-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.7rem 1.3rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      transition: all 0.2s ease;
      border: 2px solid transparent;
    }
    .cta-btn.primary {
      background: #4CC9F0;
      color: #134675;
    }
    .cta-btn.primary:hover {
      background: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 16px rgba(76, 201, 240, 0.35);
    }
    .cta-btn.secondary {
      background: transparent;
      color: #4CC9F0;
      border-color: #4CC9F0;
    }
    .cta-btn.secondary:hover {
      background: #4CC9F0;
      color: #134675;
      transform: translateY(-2px);
    }
    .cta-btn.tertiary {
      background: transparent;
      color: #F4C430;
      border-color: #F4C430;
    }
    .cta-btn.tertiary:hover {
      background: #F4C430;
      color: #134675;
      transform: translateY(-2px);
    }
    .cta-hint {
      color: #7ba3bf !important;
      font-size: 0.85rem !important;
      margin: 0 !important;
    }

    /* ── Dark mode ── */
    :global([data-theme="dark"]) .hero-section {
      background: linear-gradient(135deg, #0d1b2a 0%, #132f4c 50%, #1a2332 100%);
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .hero-tagline { color: #e2e8f0; }
    :global([data-theme="dark"]) .hero-description { color: #94a3b8; }
    :global([data-theme="dark"]) .stat-number { color: #4CC9F0; }
    :global([data-theme="dark"]) .stat-label { color: #94a3b8; }
    :global([data-theme="dark"]) .stat-divider { background: #334155; }

    :global([data-theme="dark"]) .way-card {
      background: #0f172a;
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .way-card:hover { border-color: #4CC9F0; }
    :global([data-theme="dark"]) .way-card h3 { color: #e2e8f0; }
    :global([data-theme="dark"]) .way-card p { color: #94a3b8; }

    :global([data-theme="dark"]) .contributor-link {
      background: #0f172a;
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .contributor-link:hover { border-color: #4CC9F0; }
    :global([data-theme="dark"]) .username { color: #e2e8f0; }
    :global([data-theme="dark"]) .repo { color: #94a3b8; }

    :global([data-theme="dark"]) .steps-section {
      background: linear-gradient(135deg, #0d1b2a 0%, #132f4c 100%);
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .step-content h3 { color: #e2e8f0; }
    :global([data-theme="dark"]) .step-content p { color: #94a3b8; }
    :global([data-theme="dark"]) .step-content code {
      background: #1e293b;
      color: #e2e8f0;
    }

    :global([data-theme="dark"]) .why-item {
      background: #0f172a;
      border-color: #1e3a5f;
    }
    :global([data-theme="dark"]) .why-item:hover { border-color: #F4C430; }
    :global([data-theme="dark"]) .why-item strong { color: #e2e8f0; }
    :global([data-theme="dark"]) .why-item p { color: #94a3b8; }

    :global([data-theme="dark"]) .section-title { color: #e2e8f0; }
    :global([data-theme="dark"]) .section-subtitle { color: #94a3b8; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .contributors-list { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
      .ways-grid { grid-template-columns: 1fr 1fr; }
      .why-grid { grid-template-columns: 1fr; }
      .hero-stats { gap: 1.25rem; }
      .stat-number { font-size: 1.5rem; }
      .cta-actions { flex-direction: column; align-items: center; }
    }
    @media (max-width: 420px) {
      .ways-grid { grid-template-columns: 1fr; }
    }

    /* ── Animation ── */
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .contributor-card {
      animation: fadeInUp 0.3s ease forwards;
    }
    .contributor-card:nth-child(n) {
      animation-delay: calc(var(--i, 0) * 50ms);
    }
  </style>

  <script>
    document.querySelectorAll('.contributor-card').forEach((item, index) => {
      (item as HTMLElement).style.setProperty('--i', index.toString());
